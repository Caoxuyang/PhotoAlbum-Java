# PhotoAlbum Database Configuration
# Copy this file to .env and fill in strong, unique values.
# NEVER commit the .env file to source control.
# Use a password manager or secret store to generate and manage these values.

# Oracle SYSTEM/SYS admin password (used by gvenzl/oracle-free container)
# Minimum 12 characters, mix of upper/lower case, numbers, and special characters
ORACLE_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Application database username
DB_USERNAME=photoalbum

# Application database password (used by both Oracle container and Spring Boot app)
# Minimum 12 characters, mix of upper/lower case, numbers, and special characters
DB_PASSWORD=REPLACE_WITH_STRONG_APP_PASSWORD
