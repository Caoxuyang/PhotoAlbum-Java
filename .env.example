# Photo Album - Environment Variables Example
# Copy this file to .env and set secure values before running docker-compose.
# The .env file is listed in .gitignore and must NEVER be committed to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env and set a strong password for DB_PASSWORD
#   docker-compose up --build -d

# -----------------------------------------------------------------------
# DB_PASSWORD: Shared credential used for:
#   - Oracle SYSTEM / SYS password           (ORACLE_PASSWORD in Oracle container)
#   - Application DB user password            (APP_USER_PASSWORD in Oracle container)
#   - Spring Boot datasource password         (spring.datasource.password)
#
# Choose a strong, unique password (min 12 characters, mixed case, digits,
# and special characters). Example: openssl rand -base64 24
# -----------------------------------------------------------------------
DB_PASSWORD=change_me_to_a_strong_password

# -----------------------------------------------------------------------
# POSTGRES_ADMIN_PASSWORD: Azure PostgreSQL admin password (azure-setup.ps1 only)
# Required only when provisioning Azure resources with azure-setup.ps1.
# -----------------------------------------------------------------------
POSTGRES_ADMIN_PASSWORD=change_me_to_a_strong_admin_password
