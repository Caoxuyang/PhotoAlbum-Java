# Database credentials
# Copy this file to .env and set the values before running the application.
#
# Docker Compose automatically loads variables from .env in the same directory.
# For non-Docker environments, export these variables in your shell:
#   export DB_USERNAME=your_db_username
#   export DB_PASSWORD=your_db_password
#
# Oracle password requirements: minimum 8 characters, must contain at least
# one uppercase letter, one lowercase letter, and one digit.
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
