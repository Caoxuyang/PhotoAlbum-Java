# PhotoAlbum-Java Environment Variables
#
# Copy this file to .env and fill in the actual values before running the application.
# The .env file is excluded from version control (see .gitignore) to prevent
# committing credentials to the repository.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your own secure values
#   docker compose up

# Oracle Database SYSTEM/SYS administrator password.
# Used by gvenzl/oracle-free container image to initialise the database.
# Must be set to a strong password in non-development environments.
ORACLE_PASSWORD=<your-secure-oracle-sys-password>

# Application database credentials.
# DB_USERNAME is the Oracle schema owner created for the PhotoAlbum application.
# DB_PASSWORD is the corresponding password for that schema.
# These values are injected into:
#   - docker-compose.yml  (APP_USER / APP_USER_PASSWORD / SPRING_DATASOURCE_* env vars)
#   - Spring Boot properties files (spring.datasource.username / spring.datasource.password)
DB_USERNAME=<your-db-username>
DB_PASSWORD=<your-secure-db-password>
