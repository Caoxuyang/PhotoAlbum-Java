# Environment variables for PhotoAlbum-Java
# Copy this file to .env and set your own values.
# The .env file is gitignored and must NOT be committed to source control.

# Database username
DB_USERNAME=YOUR_DB_USERNAME

# Database password – change this to a strong, unique password
DB_PASSWORD=YOUR_DB_PASSWORD

# Oracle SYSTEM/SYS password – change this to a strong, unique password
ORACLE_PASSWORD=YOUR_ORACLE_PASSWORD
