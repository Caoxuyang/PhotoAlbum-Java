# Copy this file to .env and fill in your actual credentials.
# The .env file is listed in .gitignore and must never be committed.

# Database username for the PhotoAlbum application schema
DB_USERNAME=

# Database password for the PhotoAlbum application schema
# Recommended: at least 12 characters, mixing uppercase, lowercase, digits, and special characters
DB_PASSWORD=

# Oracle SYS (admin) password used when initialising the Oracle container
# Recommended: at least 12 characters, mixing uppercase, lowercase, digits, and special characters
ORACLE_PASSWORD=
